# Server
PORT=3000
NODE_ENV=development
BASE_URL=https://your-domain.com

# Admin
ADMIN_API_KEY=your-random-admin-key

# Encryption (used to encrypt tokens at rest)
ENCRYPTION_KEY=your-32-char-random-string

# Microsoft Azure App
MS_CLIENT_ID=your-azure-app-client-id
MS_CLIENT_SECRET=your-azure-app-client-secret
MS_TENANT_ID=common
MS_REDIRECT_URI=https://your-domain.com/auth/microsoft/callback

# GoHighLevel Marketplace App
GHL_CLIENT_ID=your-ghl-app-client-id
GHL_CLIENT_SECRET=your-ghl-app-client-secret
GHL_REDIRECT_URI=https://your-domain.com/auth/ghl/callback

# GHL Webhook secret (optional, for verifying inbound webhooks)
GHL_WEBHOOK_SECRET=your-webhook-secret
